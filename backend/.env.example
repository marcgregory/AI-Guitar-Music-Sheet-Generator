# Database (Production: Use PostgreSQL)
DATABASE_URL=sqlite:///./test.db

# Processing mode
# local: development fallback with Celery/Redis for very short files only
# external_worker: backend queues jobs for a manual worker such as Kaggle
# modal: preferred production-like selected-stem GPU processing
PROCESSING_MODE=local
WORKER_API_TOKEN=change-this-worker-token
STALE_TRANSCRIPTION_TIMEOUT_SECONDS=7200

# Redis (needed for local Celery fallback/status coordination)
REDIS_URL=redis://localhost:6379/0

# Celery (PROCESSING_MODE=local only)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Modal (PROCESSING_MODE=modal)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
# Optional HTTP trigger for a Modal web endpoint. If unset, modal mode leaves
# jobs queued for /api/v1/worker/jobs/next polling.
MODAL_TRIGGER_URL=
BACKEND_API_URL=

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=your-super-secret-key-change-this-in-production
# Preferred production name. If unset, the app falls back to SECRET_KEY.
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production

# CORS Origins (comma-separated for production; use origins only, no paths)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File upload
MAX_UPLOAD_SIZE=104857600
ALLOWED_AUDIO_EXTENSIONS=.mp3,.wav
UPLOAD_DIR=/app/uploads

# Optional: YouTube may require auth/bot verification from cloud hosts.
# Use a Netscape cookies.txt file path in the container, or paste the raw
# cookies.txt contents into YOUTUBE_COOKIES in your hosting provider.
YOUTUBE_COOKIES_FILE=
YOUTUBE_COOKIES=

# Cloudinary durable storage
# Either set CLOUDINARY_URL or the three individual values.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=musicstudio

# Environment
ENVIRONMENT=development
