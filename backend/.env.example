# Local development
ENVIRONMENT=development
AUDIO_PROCESSING_MODE=local
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Production
# ENVIRONMENT=production
# AUDIO_PROCESSING_MODE=modal
# MODAL_TRIGGER_URL=https://your-modal-web-endpoint.example

# Disable processing without leaving jobs queued forever
# AUDIO_PROCESSING_MODE=disabled

# Database (Production: Use PostgreSQL)
DATABASE_URL=sqlite:///./test.db

WORKER_API_TOKEN=change-this-worker-token
# Required for /api/v1/admin/*; leave unset to disable admin API.
ADMIN_API_TOKEN=
STALE_TRANSCRIPTION_TIMEOUT_SECONDS=1800
MODAL_RATE_LIMIT_BASE_BACKOFF_SECONDS=60
MODAL_RATE_LIMIT_MAX_BACKOFF_SECONDS=900
MODAL_MAX_DISPATCH_RETRIES=5

# Local/free vocal lyrics transcription
# Railway CPU containers should prefer tiny or base.
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
WHISPER_LANGUAGE=auto
WHISPER_BEAM_SIZE=8
WHISPER_BEST_OF=5
WHISPER_VAD_FILTER=false
WHISPER_CONDITION_ON_PREVIOUS_TEXT=false
WHISPER_INITIAL_PROMPT=Transcribe the sung lyrics exactly as heard. Preserve Tagalog, Cebuano/Bisaya, English, and mixed-language phrases. Do not translate. Keep repeated chorus lines.

# Modal (required when AUDIO_PROCESSING_MODE=modal)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_TRIGGER_URL=
BACKEND_API_URL=

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=your-super-secret-key-change-this-in-production
# Preferred production name. If unset, the app falls back to SECRET_KEY.
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production

# CORS Origins (comma-separated for production; use origins only, no paths)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File upload
MAX_UPLOAD_SIZE=104857600
ALLOWED_AUDIO_EXTENSIONS=.mp3,.wav
UPLOAD_DIR=/app/uploads

# Optional: YouTube may require auth/bot verification from cloud hosts.
# For Render/hosted deploys, prefer YOUTUBE_COOKIES_B64: base64 encode the
# full raw Netscape-format cookies.txt contents exported from your browser.
# YOUTUBE_COOKIES also works, but hosted env editors may mangle newlines/tabs.
# YOUTUBE_COOKIES_FILE only works when that real file exists in the container
# or is mounted as a secret; placeholder cookie files are treated as invalid.
# If YouTube still rejects valid cookies, provide the PO token value. If you
# already have a full client-scoped value like mweb.gvs+TOKEN, that also works.
# Optional: set YOUTUBE_PLAYER_CLIENT only when explicitly testing a client.
YOUTUBE_COOKIES_FILE=
YOUTUBE_COOKIES=
YOUTUBE_COOKIES_B64=
YOUTUBE_PO_TOKEN=
YOUTUBE_PLAYER_CLIENT=
YOUTUBE_VISITOR_DATA=
# YOUTUBE_PLAYER_CLIENTS=

# Cloudinary durable storage
# Either set CLOUDINARY_URL or the three individual values.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=musicstudio

ENABLE_USAGE_LIMITS=true
DAILY_PROCESSING_JOB_LIMIT=5 or whatever limit you want
MAX_ACTIVE_JOBS_PER_USER=1
